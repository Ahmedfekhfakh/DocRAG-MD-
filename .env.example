QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=medical_rag
DENSE_DIM=768
DENSE_MODEL=pritamdeka/PubMedBERT-mnli-snli-scinli-scitail-mednli-stsb
SPARSE_STATE_PATH=data/sparse_embedder_state.json
AUTO_INGEST=0
INGEST_LIMIT=

# LLM API keys
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=

# BioMistral local via llama.cpp
BIOMISTRAL_URL=http://llama-cpp:8080/v1

CRAG_CONFIDENCE_THRESHOLD=0.60

# Langfuse observability (fill after creating a project at http://localhost:3001)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# Langfuse infrastructure secrets (generate with: openssl rand -hex 32)
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
LANGFUSE_SALT=changeme-generate-with-openssl-rand-hex-32
LANGFUSE_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32
